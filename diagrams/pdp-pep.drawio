        <mxCell id="e2" value="2 · can subject do action on resource?" style="sketch=1;curveFitting=1;jiggle=2;strokeColor=#6366f1;endArrow=block;endFill=1;fontSize=9;fontColor=#1e1b4b;labelBackgroundColor=#ffffff;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" source="pep" target="pdp" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
