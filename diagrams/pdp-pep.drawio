        <mxCell id="pep" value="Application&#10;[ PEP ]&#10;enforces the decision" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#eef2ff;strokeColor=#4f46e5;fontColor=#1e1b4b;fontStyle=1;arcSize=12;" vertex="1" parent="1">
