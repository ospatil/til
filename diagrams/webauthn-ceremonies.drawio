          <mxGeometry x="448" y="552" width="257" height="28" as="geometry" />
        </mxCell>
        <mxCell id="ft" value="The private key never leaves the authenticator. The server only ever stores a public key, so a breach of its tables leaks nothing usable - and the key is bound to the origin, so a look-alike site gets no signature." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#eef2ff;strokeColor=#4f46e5;fontColor=#1e1b4b;fontSize=10;arcSize=6;" vertex="1" parent="1">
