---
// --- Discover Markdown pages from src/pages/ ---
const mdFiles = import.meta.glob(['./**/*.md'], { eager: true })
const mdLinks = await Promise.all(
  Object.entries(mdFiles)
    .filter(([p]) => !p.includes('index'))
    .map(async ([p, mod]) => {
      const url = p.replace(/\.md$/, '/').replace(/^\./, '')
      let title = mod.frontmatter?.title
      if (!title && mod.getHeadings) {
        const headings = await mod.getHeadings()
        title = headings.find(h => h.depth === 1)?.text
      }
      const tags = mod.frontmatter?.tags || []
      return { url, title: title || url.split('/').filter(Boolean).pop(), tags }
    })
)

// --- Discover HTML pages from public/ (including subfolders) ---
const htmlRaw = import.meta.glob('/public/**/*.html', { eager: true, query: '?raw', import: 'default' })
const htmlLinks = Object.entries(htmlRaw).map(([p, raw]) => {
  const file = p.replace(/^\/public/, '')
  const content = String(raw)
  const title = content.match(/<h1[^>]*>(.*?)<\/h1>/i)?.[1]
    || content.match(/<title>(.*?)<\/title>/i)?.[1]
    || file.split('/').pop().replace(/\.html$/, '')
  const tagsMatch = content.match(/<meta\s+name="tags"\s+content="([^"]*)"/i)
  const tags = tagsMatch ? tagsMatch[1].split(',').map(t => t.trim()).filter(Boolean) : []
  return { url: file, title, tags }
})

// Merge both sources and sort alphabetically by title
const links = [...mdLinks, ...htmlLinks].sort((a, b) => a.title.localeCompare(b.title))

// Split into guides and TILs
const guides = links.filter(l => l.tags.includes('guide'))
const tils = links.filter(l => !l.tags.includes('guide'))

// Group TILs by first letter
const tilGroups = tils.reduce((acc, item) => {
  const letter = (item.title[0] || '#').toUpperCase()
  if (!acc[letter]) acc[letter] = []
  acc[letter].push(item)
  return acc
}, {} as Record<string, typeof tils>)
const sortedLetters = Object.keys(tilGroups).sort()

// Collect all unique tags sorted alphabetically
const allTags = [...new Set(links.flatMap(l => l.tags))].sort()
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="viewport" content="width=device-width" />
    <title>TIL</title>
  </head>
  <body>
    <main class="container">
      <header>
        <h1>Today I Learned</h1>
        <pagefind-searchbox></pagefind-searchbox>
      </header>
      <div class="filter-bar">
        <button class="filter-toggle" aria-expanded="false" aria-controls="tag-panel">
          <span class="filter-label">Filter by tag</span>
          <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <span class="active-filter-badge" hidden></span>
      </div>
      <nav class="tags" id="tag-panel" aria-label="Filter by tag">
        <button class="tag active" data-tag="">All</button>
        {allTags.map(tag => <button class="tag" data-tag={tag}>{tag}</button>)}
      </nav>

      <section class="guides-section">
        <h2 class="section-title sticky-section-title">Guides</h2>
        <ul class="guides-list">
          {guides.map(p => (
            <li data-tags={p.tags.join(',')}>
              <a href={p.url}>{p.title}</a>
              {p.tags.length > 0 && (
                <span class="item-tags">
                  {p.tags.filter(t => t !== 'guide').map(t => <button class="item-tag" data-filter-tag={t}>{t}</button>)}
                </span>
              )}
            </li>
          ))}
        </ul>
      </section>

      <section class="tils-section">
        <h2 class="section-title">Notes</h2>
        <div class="tils-list">
          {sortedLetters.map(letter => (
            <>
              <h3 class="letter-heading" data-letter={letter}>{letter}</h3>
              {tilGroups[letter].map(p => (
                <div class="til-item" data-tags={p.tags.join(',')} data-letter-group={letter}>
                  <a href={p.url}>{p.title}</a>
                  {p.tags.length > 0 && (
                    <span class="item-tags">
                      {p.tags.map(t => <button class="item-tag" data-filter-tag={t}>{t}</button>)}
                    </span>
                  )}
                </div>
              ))}
            </>
          ))}
        </div>
      </section>
    </main>
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet">
    <script src="/pagefind/pagefind-component-ui.js" type="module" is:inline></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.querySelector('.filter-toggle');
        const panel = document.getElementById('tag-panel');
        const badge = document.querySelector('.active-filter-badge');
        const navButtons = document.querySelectorAll('.tags .tag');
        const items = document.querySelectorAll('[data-tags]');
        const letterHeadings = document.querySelectorAll('.letter-heading[data-letter]');
        const guidesSection = document.querySelector('.guides-section');
        const tilsSection = document.querySelector('.tils-section');

        toggle.addEventListener('click', () => {
          const isOpen = panel.classList.contains('open');
          panel.classList.toggle('open');
          toggle.setAttribute('aria-expanded', !isOpen);
          toggle.classList.toggle('open');
        });

        function filterByTag(tag) {
          navButtons.forEach(b => b.classList.remove('active'));
          const activeBtn = document.querySelector(`.tags .tag[data-tag="${tag}"]`);
          if (activeBtn) activeBtn.classList.add('active');

          items.forEach(item => {
            if (!tag) {
              item.style.display = '';
            } else {
              const tags = item.dataset.tags.split(',');
              item.style.display = tags.includes(tag) ? '' : 'none';
            }
          });

          // Hide empty letter headings
          letterHeadings.forEach(heading => {
            const letter = heading.dataset.letter;
            const groupItems = document.querySelectorAll(`.til-item[data-letter-group="${letter}"]`);
            const hasVisible = [...groupItems].some(el => el.style.display !== 'none');
            heading.style.display = (!tag || hasVisible) ? '' : 'none';
          });

          // Hide guides section if no visible items
          if (tag) {
            const visibleGuides = guidesSection.querySelectorAll('[data-tags]:not([style*="display: none"])');
            guidesSection.style.display = visibleGuides.length > 0 ? '' : 'none';
          } else {
            guidesSection.style.display = '';
          }

          if (tag) {
            badge.textContent = tag;
            badge.hidden = false;
          } else {
            badge.hidden = true;
          }
        }

        navButtons.forEach(btn => {
          btn.addEventListener('click', () => filterByTag(btn.dataset.tag));
        });

        document.querySelectorAll('.item-tag[data-filter-tag]').forEach(btn => {
          btn.addEventListener('click', () => filterByTag(btn.dataset.filterTag));
        });

        badge.addEventListener('click', () => filterByTag(''));
      });
    </script>
  </body>
</html>
<style>
  :root {
    --background: #fafafa;
    --foreground: #1e1b4b;
    --muted: #f1f5f9;
    --muted-foreground: #64748b;
    --accent: #4f46e5;
    --border: #e2e8f0;
    --radius: 0.5rem;
  }
  html {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--background);
    color: var(--foreground);
  }
  body {
    margin: 0;
    padding: 2.5rem 1rem;
  }
  .container {
    max-width: 60rem;
    margin: 0 auto;
  }
  h1 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--accent);
  }
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  pagefind-searchbox {
    width: 14rem;
  }
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .filter-toggle {
    appearance: none;
    border: 1px solid var(--border);
    background: var(--background);
    color: var(--muted-foreground);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.8125rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: all 0.15s;
  }
  .filter-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .filter-toggle .chevron {
    transition: transform 0.2s;
  }
  .filter-toggle.open .chevron {
    transform: rotate(180deg);
  }
  .active-filter-badge {
    font-size: 0.75rem;
    font-weight: 500;
    color: white;
    background: var(--accent);
    padding: 0.1875rem 0.5rem;
    border-radius: 9999px;
    cursor: pointer;
  }
  .active-filter-badge:hover {
    opacity: 0.8;
  }
  .tags {
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
    padding: 0.75rem;
    background: var(--muted);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: none;
  }
  .tags.open {
    display: flex;
  }
  .tag {
    appearance: none;
    border: 1px solid var(--border);
    background: #e8e5fc;
    color: #5b4fc7;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .tag.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }
  .section-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--foreground);
    margin: 1.5rem 0 0.5rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border);
  }
  .sticky-section-title {
    position: sticky;
    top: 0;
    background: var(--background);
    z-index: 2;
    padding-top: 0.375rem;
  }
  .guides-section .section-title {
    margin-top: 0.5rem;
  }
  .tils-list {
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
  }
  .letter-heading {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--muted-foreground);
    margin: 0.75rem 0 0.25rem;
    padding: 0.25rem 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    position: sticky;
    top: 0;
    background: var(--background);
    z-index: 1;
  }
  .til-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .til-item a {
    display: block;
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius);
    color: var(--foreground);
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.15s;
    flex: 1;
  }
  .til-item a:hover {
    background: var(--muted);
    border-color: var(--border);
    color: var(--accent);
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
  }
  li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  li a {
    display: block;
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius);
    color: var(--foreground);
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.15s;
    flex: 1;
  }
  li a:hover {
    background: var(--muted);
    border-color: var(--border);
    color: var(--accent);
  }
  .guides-list li a {
    font-weight: 500;
  }
  .item-tags {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
    padding-right: 0.5rem;
  }
  .item-tag {
    appearance: none;
    border: none;
    font-size: 0.6875rem;
    color: #5b4fc7;
    background: #eeecfb;
    padding: 0.125rem 0.4375rem;
    border-radius: 9999px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .item-tag:hover {
    background: #ddd8f7;
  }
  @media (max-width: 48rem) {
    body { padding: 1.5rem 1rem; }
    .item-tags { display: none; }
  }
</style>
