---
import 'github-markdown-css/github-markdown-light.css'

const mdFiles = import.meta.glob(['./**/*.md'], { eager: true })
const mdLinks = await Promise.all(
  Object.entries(mdFiles)
    .filter(([p]) => !p.includes('index'))
    .map(async ([p, mod]) => {
      const url = p.replace(/\.md$/, '/').replace(/^\./, '')
      let title = mod.frontmatter?.title
      if (!title && mod.getHeadings) {
        const headings = await mod.getHeadings()
        title = headings.find(h => h.depth === 1)?.text
      }
      return { url, title: title || url.split('/').filter(Boolean).pop() }
    })
)

const htmlRaw = import.meta.glob('/public/**/*.html', { eager: true, query: '?raw', import: 'default' })
const htmlLinks = Object.entries(htmlRaw).map(([p, raw]) => {
  const file = p.split('/').pop()
  const content = String(raw)
  const title = content.match(/<h1[^>]*>(.*?)<\/h1>/i)?.[1]
    || content.match(/<title>(.*?)<\/title>/i)?.[1]
    || file.replace(/\.html$/, '')
  return { url: `/${file}`, title }
})

const links = [...mdLinks, ...htmlLinks].sort((a, b) => a.title.localeCompare(b.title))
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="viewport" content="width=device-width" />
    <title>TIL</title>
  </head>
  <body>
    <article class="markdown-body">
      <h1>Today I Learned</h1>
      <ul>
        {links.map(p => <li><a href={p.url}>{p.title}</a></li>)}
      </ul>
    </article>
  </body>
</html>
<style>
  .markdown-body {
    box-sizing: border-box;
    min-width: 12.5rem;
    max-width: 61.25rem;
    margin: 0 auto;
    padding: 2.8rem;
  }
  @media (max-width: 48rem) {
    .markdown-body {
      padding: 1rem;
    }
  }
</style>
