---
// --- Discover Markdown pages from src/pages/ ---
// Glob all .md files under src/pages/, excluding the index page itself.
// Title is resolved from: frontmatter.title → first h1 heading → filename fallback.
const mdFiles = import.meta.glob(['./**/*.md'], { eager: true })
const mdLinks = await Promise.all(
  Object.entries(mdFiles)
    .filter(([p]) => !p.includes('index'))
    .map(async ([p, mod]) => {
      const url = p.replace(/\.md$/, '/').replace(/^\./, '')
      let title = mod.frontmatter?.title
      if (!title && mod.getHeadings) {
        const headings = await mod.getHeadings()
        title = headings.find(h => h.depth === 1)?.text
      }
      return { url, title: title || url.split('/').filter(Boolean).pop() }
    })
)

// --- Discover HTML pages from public/ (including subfolders) ---
// Glob all .html files under public/, imported as raw strings to extract titles.
// URL is derived by stripping the /public prefix, preserving subfolder structure.
// e.g. /public/pages/foo.html → /pages/foo.html
// Title is resolved from: <h1> → <title> → filename fallback.
const htmlRaw = import.meta.glob('/public/**/*.html', { eager: true, query: '?raw', import: 'default' })
const htmlLinks = Object.entries(htmlRaw).map(([p, raw]) => {
  const file = p.replace(/^\/public/, '')
  const content = String(raw)
  const title = content.match(/<h1[^>]*>(.*?)<\/h1>/i)?.[1]
    || content.match(/<title>(.*?)<\/title>/i)?.[1]
    || file.split('/').pop().replace(/\.html$/, '')
  return { url: file, title }
})

// Merge both sources and sort alphabetically by title
const links = [...mdLinks, ...htmlLinks].sort((a, b) => a.title.localeCompare(b.title))
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="viewport" content="width=device-width" />
    <title>TIL</title>
  </head>
  <body>
    <main class="container">
      <header>
        <h1>Today I Learned</h1>
        <pagefind-searchbox></pagefind-searchbox>
      </header>
      <ul>
        {links.map(p => <li><a href={p.url}>{p.title}</a></li>)}
      </ul>
    </main>
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet">
    <script src="/pagefind/pagefind-component-ui.js" type="module" is:inline></script>
  </body>
</html>
<style>
  :root {
    --background: #fafafa;
    --foreground: #1e1b4b;
    --muted: #f1f5f9;
    --muted-foreground: #64748b;
    --accent: #4f46e5;
    --border: #e2e8f0;
    --radius: 0.5rem;
  }
  html {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--background);
    color: var(--foreground);
  }
  body {
    margin: 0;
    padding: 2.5rem 1rem;
  }
  .container {
    max-width: 42rem;
    margin: 0 auto;
  }
  h1 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--accent);
  }
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  pagefind-searchbox {
    width: 14rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  li a {
    display: block;
    padding: 0.625rem 0.875rem;
    border-radius: var(--radius);
    color: var(--foreground);
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.15s;
  }
  li a:hover {
    background: var(--muted);
    border-color: var(--border);
    color: var(--accent);
  }
  @media (max-width: 48rem) {
    body { padding: 1.5rem 1rem; }
  }
</style>
